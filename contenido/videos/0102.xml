xto>	</subtitulo>	<subtitulo>		<idSubtitulo>26</idSubtitulo>		<tiempoIni>63.29</tiempoIni>		<tiempoFin>65.18</tiempoFin>		<texto>Then it's just work!</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>27</idSubtitulo>		<tiempoIni>65.18</tiempoIni>		<tiempoFin>67.26</tiempoFin>		<texto>Oh. So, are you a teacher?</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>28</idSubtitulo>		<tiempoIni>67.26</tiempoIni>		<tiempoFin>69.24</tiempoFin>		<texto>Yes, an English teacher.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>29</idSubtitulo>		<tiempoIni>69.24</tiempoIni>		<tiempoFin>70.84</tiempoFin>		<texto>Wow! That's wonderful.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>30</idSubtitulo>		<tiempoIni>70.84</tiempoIni>		<tiempoFin>72.21</tiempoFin>		<texto>Thanks, Sarah.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>31</idSubtitulo>		<tiempoIni>72.21</tiempoIni>		<tiempoFin>74.28</tiempoFin>		<texto>Bye!</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>32</idSubtitulo>		<tiempoIni>74.28</tiempoIni>		<tiempoFin>76.77</tiempoFin>		<texto>Your show is great!*My students love it!</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>33</idSubtitulo>		<tiempoIni>76.77</tiempoIni>		<tiempoFin>78.1</tiempoFin>		<texto>Thanks!</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>34</idSubtitulo>		<tiempoIni>79.17</tiempoIni>		<tiempoFin>80.58</tiempoFin>		<texto>Thanks, Kate.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>35</idSubtitulo>		<tiempoIni>80.58</tiempoIni>		<tiempoFin>81.7</tiempoFin>		<texto>On video chat is Pedro.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>36</idSubtitulo>		<tiempoIni>82.23</tiempoIni>		<tiempoFin>83.69</tiempoFin>		<texto>Pedro, where are you from?</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>37</idSubtitulo>		<tiempoIni>83.69</tiempoIni>		<tiempoFin>86.05</tiempoFin>		<texto>Hi, Simon!*I'm from Santiago, Chile!</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>38</idSubtitulo>		<tiempoIni>87.9</tiempoIni>		<tiempoFin>88.873</tiempoFin>		<texto>And what's your job?</