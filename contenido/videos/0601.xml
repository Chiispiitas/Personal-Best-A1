<?xml version="1.0" encoding="UTF-8"?><subtitulos>	<subtitulo>		<idSubtitulo>1</idSubtitulo>		<tiempoIni>14.1</tiempoIni>		<tiempoFin>17.77</tiempoFin>		<texto>I usually like helping people</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>2</idSubtitulo>		<tiempoIni>17.77</tiempoIni>		<tiempoFin>19.35</tiempoFin>		<texto>and talking to them.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>3</idSubtitulo>		<tiempoIni>19.35</tiempoIni>		<tiempoFin>21.52</tiempoFin>		<texto>I often ask a lot of questions.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>4</idSubtitulo>		<tiempoIni>21.52</tiempoIni>		<tiempoFin>23.17</tiempoFin>		<texto>It's my job at Learning Curve!</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>5</idSubtitulo>		<tiempoIni>23.87</tiempoIni>		<tiempoFin>27.4</tiempoFin>		<texto>But, there are days when people*ask me a lot of questions.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>6</idSubtitulo>		<tiempoIni>28.12</tiempoIni>		<tiempoFin>30.93</tiempoFin>		<texto>This usually happens*when I walk to the studio</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>7</idSubtitulo>		<tiempoIni>30.93</tiempoIni>		<tiempoFin>32.33</tiempoFin>		<texto>from the Underground station.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>8</idSubtitulo>		<tiempoIni>33.47</tiempoIni>		<tiempoFin>35.16</tiempoFin>		<texto>Here’s my day.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>9</idSubtitulo>		<tiempoIni>35.16</tiempoIni>		<tiempoFin>37.61</tiempoFin>		<texto>I get up at 7.30 a.m.,</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>10</idSubtitulo>		<tiempoIni>37.61</tiempoIni>		<tiempoFin>38.95</tiempoFin>		<texto>I have breakfast</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>11</idSubtitulo>		<tiempoIni>38.95</tiempoIni>		<tiempoFin>41.66</tiempoFin>		<texto>– the usual, eggs,*toast and tea.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>12</idSubtitulo>		<tiempoIni>42.46</tiempoIni>		<tiempoFin>44.68</tiempoFin>		<texto>I cycle to work*when the weather is good.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>13</idSubtitulo>		<tiempoIni>45.57</tiempoIni>		<tiempoFin>48.45</tiempoFin>		<texto>I don't have a car*because I can't drive.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>14</idSubtitulo>		<tiempoIni>49.44</tiempoIni>		<tiempoFin>51.57</tiempoFin>		<texto>But, when it rains?</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>15</idSubtitulo>		<tiempoIni>51.57</tiempoIni>		<tiempoFin>53.77</tiempoFin>		<texto>Well, on those days,</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>16</idSubtitulo>		<tiempoIni>53.77</tiempoIni>		<tiempoFin>55.49</tiempoFin>		<texto>I take the Underground train,</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>17</idSubtitulo>		<tiempoIni>56.12</tiempoIni>		<tiempoFin>58.88</tiempoFin>		<texto>and then walk for fifteen minutes.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>18</idSubtitulo>		<tiempoIni>59.81</tiempoIni>		<tiempoFin>61.23</tiempoFin>		<texto>I don't like the Underground.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>19</idSubtitulo>		<tiempoIni>63.08</tiempoIni>		<tiempoFin>65.23</tiempoFin>		<texto>Baah! But, I do like walking.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>20</idSubtitulo>		<tiempoIni>66.8</tiempoIni>		<tiempoFin>68.35</tiempoFin>		<texto>There's one small problem.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>21</idSubtitulo>		<tiempoIni>69.29</tiempoIni>		<tiempoFin>72.03</tiempoFin>		<texto>When I walk to or*from the station,</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>22</idSubtitulo>		<tiempoIni>72.03</tiempoIni>		<tiempoFin>74.56</tiempoFin>		<texto>I'm Simon, the map!</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>23</idSubtitulo>		<tiempoIni>75.72</tiempoIni>		<tiempoFin>77.14</tiempoFin>		<texto>Look at me!</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>24</idSubtitulo>		<tiempoIni>77.14</tiempoIni>		<tiempoFin>79.14</tiempoFin>		<texto>Am I a map?</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>25</idSubtitulo>		<tiempoIni>80.31</tiempoIni>		<tiempoFin>82.01</tiempoFin>		<texto>OK. Time to go.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>26</idSubtitulo>		<tiempoIni>88.54</tiempoIni>		<tiempoFin>90.11</tiempoFin>		<texto>There's the station!</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>27</idSubtitulo>		<tiempoIni>90.11</tiempoIni>		<tiempoFin>91.63</tiempoFin>		<texto>Kate always calls*it ‘the Subway’</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>28</idSubtitulo>		<tiempoIni>91.63</tiempoIni>		<tiempoFin>94.12</tiempoFin>		<texto>because she's from*the U.S. Here in London,</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>29</idSubtitulo>		<tiempoIni>94.12</tiempoIni>		<tiempoFin>95.45</tiempoFin>		<texto>it's often called ‘the Tube’.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>30</idSubtitulo>		<tiempoIni>95.99</tiempoIni>		<tiempoFin>97.2</tiempoFin>		<texto>I don't like taking it.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>31</idSubtitulo>		<tiempoIni>97.79</tiempoIni>		<tiempoFin>99.13</tiempoFin>		<texto>No one speaks!</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>32</idSubtitulo>		<tiempoIni>99.13</tiempoIni>		<tiempoFin>100.94</tiempoFin>		<texto>People on the Tube*don't like talking.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>33</idSubtitulo>		<tiempoIni>120</tiempoIni>		<tiempoFin>123.11</tiempoFin>		<texto>Excuse me.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>34</idSubtitulo>		<tiempoIni>123.11</tiempoIni>		<tiempoFin>124.86</tiempoFin>		<texto>Is there a post office around here?</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>35</idSubtitulo>		<tiempoIni>124.86</tiempoIni>		<tiempoFin>128.3</tiempoFin>		<texto>Yes, there is. It's down the street.*Go straight on.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>36</idSubtitulo>		<tiempoIni>128.3</tiempoIni>		<tiempoFin>130.13</tiempoFin>		<texto>It's on the left,*near the car park.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>37</idSubtitulo>		<tiempoIni>130.13</tiempoIni>		<tiempoFin>131.98</tiempoFin>		<texto>Oh! Thank you very much.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>38</idSubtitulo>		<tiempoIni>131.98</tiempoIni>		<tiempoFin>134.737</tiempoFin>		<texto>No problem.</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>39</idSubtitulo>		<tiempoIni>134.737</tiempoIni>		<tiempoFin>135.9</tiempoFin>		<texto>See? Am I right?</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>40</idSubtitulo>		<tiempoIni>137</tiempoIni>		<tiempoFin>139.1</tiempoFin>		<texto>I'm Simon, the map!</texto>	</subtitulo></subtitulos>