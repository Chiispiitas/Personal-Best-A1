<?xml version="1.0" encoding="UTF-8"?><subtitulos>	<subtitulo>		<idSubtitulo>1</idSubtitulo>		<tiempoIni>14.6</tiempoIni>		<tiempoFin>16.62</tiempoFin>		<texto>Hello and welcome to Learning Curve!</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>2</idSubtitulo>		<tiempoIni>16.62</tiempoIni>		<tiempoFin>17.8</tiempoFin>		<texto>Hello!</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>3</idSubtitulo>		<tiempoIni>17.8</tiempoIni>		<tiempoFin>19.53</tiempoFin>		<texto>I like blue on you, Penny!</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>4</idSubtitulo>		<tiempoIni>19.53</tiempoIni>		<tiempoFin>24.11</tiempoFin>		<texto>Oh, thanks, Ethan.*Um, what are you wearing?</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>5</idSubtitulo>		<tiempoIni>24.11</tiempoIni>		<tiempoFin>28.28</tiempoFin>		<texto>Look! My shirt has almost*every color in it, except green!</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>6</idSubtitulo>		<tiempoIni>28.28</tiempoIni>		<tiempoFin>32.64</tiempoFin>		<texto>Right. So, Ethan, why are you*wearing that Hawaiian shirt?</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>7</idSubtitulo>		<tiempoIni>32.64</tiempoIni>		<tiempoFin>36.39</tiempoFin>		<texto>Well, because we're talking*about colors today, aren't we Penny?</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>8</idSubtitulo>		<tiempoIni>36.39</tiempoIni>		<tiempoFin>38.49</tiempoFin>		<texto>Yes, we are. See you in a bit!</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>9</idSubtitulo>		<tiempoIni>41.86</tiempoIni>		<tiempoFin>44.68</tiempoFin>		<texto>Do you wear some colors,*but not others?</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>10</idSubtitulo>		<tiempoIni>44.68</tiempoIni>		<tiempoFin>47.75</tiempoFin>		<texto>Did you know that the colors*you wear change how you feel?</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>11</idSubtitulo>		<tiempoIni>48.43</tiempoIni>		<tiempoFin>50.34</tiempoFin>		<texto>When I wear this Hawaiian shirt,</texto>	</subtitulo>	<subtitulo>		<idSubtitulo>12</idSubtitulo>		<t